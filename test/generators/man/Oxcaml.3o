
.TH Oxcaml 3 "" "Odoc" "OCaml Library"
.SH Name
Oxcaml
.SH Synopsis
.sp 
.in 2
\fBModule Oxcaml\fR
.in 
.sp 
.SH Documentation
.sp 
.nf 
\f[CB]val\fR f : int \f[CB]\->\fR ('a\. \f[CB]'a\fR \f[CB]\->\fR \f[CB]'a\fR) \f[CB]\->\fR unit
.fi 
.br 
.ti +2
Polymorphic arguments require parentheses
.nf 
.sp 
.fi 
Unboxed types have a trailing hash '#'
.nf 
.sp 
\f[CB]type\fR pt = {
.br 
.ti +2
x : int;
.br 
.ti +2
y : float32#;
.br 
}
.sp 
\f[CB]type\fR segment = {
.br 
.ti +2
start : pt#;
.br 
.ti +2
stop : pt#;
.br 
}
