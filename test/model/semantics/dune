(rule
 (copy ../../odoc_print/type_desc_to_yojson.ml type_desc_to_yojson.ml))

(executable
 (name odoc_semantic_test)
 (enabled_if
  (>= %{ocaml_version} 4.04.1))
 (libraries sexplib0 odoc_model odoc_model_desc yojson expect_test_helper))

(rule
 (with-stdout-to
  dune.inc.gen.raw
  (run %{exe:odoc_semantic_test.exe} --gen-rules)))

(rule
 (action
  (format-dune-file dune.inc.gen.raw dune.inc.gen)))

(rule
 (alias runtest)
 (package odoc)
 (action
  (diff dune.inc dune.inc.gen)))

(include dune.inc)
